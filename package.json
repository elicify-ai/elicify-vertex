{
  "name": "@elicify-ai/elicify-vertex",
  "version": "0.9.4",
  "description": "Opencode plugin that injects harness directives into the LLM input via the official chat.transform hooks — verification, evidence, and communication discipline as procedure, not luck.",
  "type": "module",
  "main": "./dist/plugin.cjs",
  "module": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "require": "./dist/plugin.cjs",
      "default": "./dist/plugin.cjs"
    },
    "./lib": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "CLA.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "SUPPORT.md",
    "TRADEMARKS.md",
    "SKILL.md",
    "skills",
    "agents",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp scripts/plugin.cjs dist/plugin.cjs",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tests.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "bash scripts/install-skill.sh",
    "uninstall": "bash scripts/uninstall.sh",
    "postinstall": "bash scripts/install-skill.sh || true",
    "uat": "node scripts/uat-harness.mjs"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "elicify",
    "elicify-vertex",
    "vertex",
    "harness",
    "verification",
    "directives"
  ],
  "author": {
    "name": "elicify.ai Pte. Ltd.",
    "email": "connect@elicify.ai",
    "url": "https://github.com/elicify-ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elicify-ai/elicify-vertex.git"
  },
  "bugs": {
    "url": "https://github.com/elicify-ai/elicify-vertex/issues"
  },
  "homepage": "https://github.com/elicify-ai/elicify-vertex#readme",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.16.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
